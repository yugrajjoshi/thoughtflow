# Copy this file to .env and customize the values for your environment.
# WARNING: Do not commit the actual .env file to version control.

# --- Django Core Settings ---
DJANGO_SECRET_KEY=replace-with-a-very-secure-random-key-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-production-domain.com

# --- Database & Cache ---
# Local development default: SQLite is used if DATABASE_URL is not set.
# Set DATABASE_URL to use PostgreSQL in production (e.g., Render Postgres).
DATABASE_URL=postgres://username:password@hostname:5432/databasename
DATABASE_CONN_MAX_AGE=600

# Cache / WebSocket Channels (Redis url)
# Defaults to in-memory channels if REDIS_URL is not set.
REDIS_URL=redis://127.0.0.1:6379/0

# --- Domain & URL Routing ---
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://127.0.0.1:8000

# --- Email Configuration ---
# Options: 'django.core.mail.backends.smtp.EmailBackend' or 'django.core.mail.backends.console.EmailBackend'
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@thoughtflow.com

# --- Google OAuth Settings ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback/

# --- Tuning Options ---
TRENDING_HASHTAG_WINDOW_HOURS=4
TRENDING_HASHTAG_MIN_POSTS=3
TRENDING_HASHTAG_LIMIT=10
