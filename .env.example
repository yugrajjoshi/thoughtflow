## Copy to .env and fill values for production
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Postgres connection (example)
DATABASE_URL=postgres://thoughtflow:changeme@db:5432/thoughtflow

# Redis for channels
REDIS_URL=redis://redis:6379/0

# Frontend/backend URLs
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://127.0.0.1:8000

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
# Django environment example (do NOT commit secrets to VCS)
# Copy this to .env and fill values for production

DJANGO_SECRET_KEY=change-me-replace-with-secure-value
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://user:pass@db-host:5432/dbname
REDIS_URL=redis://127.0.0.1:6379
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://127.0.0.1:8000

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
