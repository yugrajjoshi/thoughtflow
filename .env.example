# Django environment example (do NOT commit secrets to VCS)
# Copy this to .env and fill values for production

DJANGO_SECRET_KEY=change-me-replace-with-secure-value
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://user:pass@db-host:5432/dbname
REDIS_URL=redis://127.0.0.1:6379
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://127.0.0.1:8000

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
